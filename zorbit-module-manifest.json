{
  "manifestVersion": "2.0",
  "moduleId": "zorbit-app-sample",
  "moduleType": "app",
  "version": "0.1.0",
  "placement": {
    "scaffold": "developer_center",
    "scaffoldSortOrder": 70,
    "capabilityArea": "sample",
    "sortOrder": 10
  },
  "registration": {
    "kafkaTopic": "platform-module-announcements"
  },
  "navigation": {
    "sections": [
      {
        "id": "guide",
        "sortOrder": 0,
        "items": [
          {
            "id": "intro",
            "sortOrder": 1,
            "feRoute": "/m/sample/guide/intro",
            "feComponent": "@platform:GuideIntroView"
          },
          {
            "id": "presentation",
            "sortOrder": 2,
            "feRoute": "/m/sample/guide/presentation",
            "feComponent": "@platform:GuideSlideDeck"
          },
          {
            "id": "lifecycle",
            "sortOrder": 3,
            "feRoute": "/m/sample/guide/lifecycle",
            "feComponent": "@platform:GuideLifecycle"
          },
          {
            "id": "videos",
            "sortOrder": 4,
            "feRoute": "/m/sample/guide/videos",
            "feComponent": "@platform:GuideVideos"
          },
          {
            "id": "resources",
            "sortOrder": 5,
            "feRoute": "/m/sample/guide/resources",
            "feComponent": "@platform:GuideResources"
          },
          {
            "id": "pricing",
            "sortOrder": 6,
            "feRoute": "/m/sample/guide/pricing",
            "feComponent": "@platform:GuidePricing"
          }
        ]
      }
    ]
  },
  "guide": {
    "intro": {
      "$src": "./manifest-content/guide/intro.md"
    },
    "slides": {
      "decks": {
        "$src": "./manifest-content/guide/slides/index.json"
      }
    },
    "lifecycle": {
      "$src": "./manifest-content/guide/lifecycle.json"
    },
    "videos": {
      "playlists": {
        "$src": "./manifest-content/guide/videos/index.json"
      }
    },
    "resources": {
      "$src": "./manifest-content/guide/resources.json"
    },
    "pricing": {
      "$src": "./manifest-content/guide/pricing.json"
    }
  },
  "deployments": {
    "show": true,
    "health": {
      "beRoute": "/api/sample/api/v1/G/health"
    }
  },
  "backend": {
    "baseUrl": "http://localhost:3100",
    "apiPrefix": "/api/sample/api/v1"
  },
  "events": {
    "publishes": [],
    "subscribes": []
  },
  "errors": {
    "$src": "./manifest-content/errors.json"
  },
  "dependencies": [
    "zorbit-cor-event_bus"
  ]
}
