# =============================================================================
# zorbit-app-sample — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
# Every variable is documented below.
# =============================================================================

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
# Port this service listens on. Default: 3040
PORT=3040

# Environment: development | production | test
NODE_ENV=development

# -----------------------------------------------------------------------------
# MongoDB
# -----------------------------------------------------------------------------
# Connection URI for this module's own database.
# Each Zorbit module gets its own database — never share databases between services.
# The ?directConnection=true flag is required for replica set connections in dev.
MONGO_URI=mongodb://127.0.0.1:27018/zorbit_sample_tasks?directConnection=true

# -----------------------------------------------------------------------------
# Zorbit Platform Services
# -----------------------------------------------------------------------------
# These are the REST API base URLs for the platform services your module depends on.
# In production, these typically point to internal service mesh URLs or nginx proxies.
# In development, they point to localhost with the correct port.

# Identity service — issues JWTs, manages users and organizations.
IDENTITY_SERVICE_URL=http://localhost:3099

# Authorization service — manages roles and privileges.
AUTHORIZATION_SERVICE_URL=http://localhost:3102

# PII Vault service — tokenizes and detokenizes personally identifiable information.
PII_VAULT_SERVICE_URL=http://localhost:3105

# Navigation service — dynamic menu items and route registrations.
NAVIGATION_SERVICE_URL=http://localhost:3103

# Audit service — event audit trail.
AUDIT_SERVICE_URL=http://localhost:3106

# -----------------------------------------------------------------------------
# JWT Authentication
# -----------------------------------------------------------------------------
# This MUST match the JWT_SECRET used by zorbit-identity to sign tokens.
# If this doesn't match, all authenticated requests will fail with 401.
JWT_SECRET=your_jwt_secret_here

# -----------------------------------------------------------------------------
# Kafka (Optional — Event Publishing)
# -----------------------------------------------------------------------------
# Set KAFKA_ENABLED=true to enable event publishing to Kafka.
# When disabled, events are logged to console but not published.
KAFKA_ENABLED=false

# Kafka broker address(es). Comma-separated for multiple brokers.
KAFKA_BROKER=localhost:9092

# Unique client ID for this service instance on the Kafka cluster.
KAFKA_CLIENT_ID=zorbit-app-sample

# Consumer group ID (used if this service consumes events in the future).
KAFKA_GROUP_ID=zorbit-app-sample-group

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
# Comma-separated list of allowed origins for CORS.
# Include your frontend dev server and production domain.
CORS_ORIGINS=http://localhost:5173,https://zorbit.scalatics.com
